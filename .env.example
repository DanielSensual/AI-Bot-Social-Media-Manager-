## X (Twitter) API (OAuth 1.0a user context)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

## LinkedIn (OAuth 2.0)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional: Set this to post to a company page instead of a personal profile
# LINKEDIN_ORG_ID=

## AI Providers
# AI_PROVIDER=auto | openai | gemini | grok
AI_PROVIDER=auto
OPENAI_API_KEY=
GEMINI_API_KEY=
# Optional alias (Gemini): if set, this is used when GEMINI_API_KEY is empty.
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
XAI_API_KEY=
GROK_MODEL=grok-3

## Veo 3.1 Video (Gemini API)
# Optional override if you want a different key for video:
# VEO_API_KEY=
VIDEO_PROVIDER=auto
VEO_MODEL=veo-3.1-generate-preview
VEO_ASPECT_RATIO=9:16
VEO_RESOLUTION=720p
VEO_POLL_INTERVAL_MS=10000
VEO_MAX_WAIT_MS=720000

## Grok Video (xAI)
GROK_VIDEO_MODEL=grok-imagine-video
GROK_VIDEO_POLL_INTERVAL_MS=3000
GROK_VIDEO_MAX_WAIT_MS=360000

## Facebook Graph API
GHOSTAI_FACEBOOK_PAGE_ID=753873537816019
FACEBOOK_ACCESS_TOKEN=
# FACEBOOK_PAGE_ID=753873537816019
# FACEBOOK_PAGE_ACCESS_TOKEN=
# Daniel-specific Facebook Page manager credentials
DANIEL_FACEBOOK_ACCESS_TOKEN=
DANIEL_FACEBOOK_PAGE_ACCESS_TOKEN=
DANIEL_FACEBOOK_PAGE_ID=
# Daniel Facebook manager controls
DANIEL_FACEBOOK_MANAGER_ENABLED=true
DANIEL_FACEBOOK_TIMEZONE=America/New_York
DANIEL_FACEBOOK_DAILY_TIME=10:00
DANIEL_FACEBOOK_AI_ENABLED=true
DANIEL_FACEBOOK_HEALTH_CHECK=true
DANIEL_FACEBOOK_RUN_ON_START=false
DANIEL_FACEBOOK_DRY_RUN=false
# Bachata daily automation
BACHATA_PAGE_ID=266552527115323
BACHATA_EVENT_CONFIG=events/bachata-pool-party/config.json
BACHATA_FORCE_USER_TOKEN=true
# Comma-separated optional song links for Daniel Sensual fallback posts
# BACHATA_DANIEL_SENSUAL_SONG_URLS=https://example.com/song1,https://example.com/song2
# Facebook inbox responder defaults (explicit page targeting required in production)
FACEBOOK_RESPONDER_PAGE_ID=
# FACEBOOK_RESPONDER_PAGE_NAME=Bachata Exotica
FACEBOOK_RESPONDER_PROFILE=default
FACEBOOK_RESPONDER_LIMIT=5

## Instagram Web Automation (for outbound engagement)
# INSTAGRAM_USERNAME=
# INSTAGRAM_PASSWORD=

## Instagram API-Only Autopilot
INSTAGRAM_AUTOPILOT_TIMEZONE=America/New_York
INSTAGRAM_AUTOPILOT_COMMENT_TIMES=09:30,16:30
INSTAGRAM_AUTOPILOT_STORY_TIMES=11:00,20:00
INSTAGRAM_AUTOPILOT_REEL_TIMES=15:00,21:00
INSTAGRAM_AUTOPILOT_COMMENT_LIMIT=8
INSTAGRAM_AUTOPILOT_POSTS_TO_SCAN=5
INSTAGRAM_AUTOPILOT_AI_REELS_PER_DAY=1
INSTAGRAM_AUTOPILOT_AI_STORIES_PER_DAY=2
INSTAGRAM_AUTOPILOT_AI_VIDEO_PROVIDER=auto

# Command Agent (for ghostai-dashboard remote command execution)
# Must match the token used by ghostai-dashboard (DASHBOARD_SECRET or COMMAND_AGENT_TOKEN)
COMMAND_AGENT_TOKEN=
# Optional aliases accepted by command-agent:
# DASHBOARD_SECRET=
# COMMAND_AGENT_HOST=0.0.0.0
# COMMAND_AGENT_PORT=8787

# PENDING: set this path when your Drive sync folder is ready.
# Expected structure:
#   $IG_DRIVE_ROOT/reels/inbox
#   $IG_DRIVE_ROOT/stories/inbox
# IG_DRIVE_ROOT=/absolute/path/to/your/drive-folder

## OpenAI Sora (optional)
SORA_MODEL=sora-2
SORA_SECONDS=8
SORA_SIZE=720x1280
SORA_POLL_INTERVAL_MS=5000
SORA_MAX_WAIT_MS=600000

## Facebook Agentic Automation
FACEBOOK_AGENT_ENABLED=true
FACEBOOK_AGENT_TIMEZONE=America/New_York
FACEBOOK_AGENT_TIMES=09:30,13:00,18:30,21:00
FACEBOOK_AGENT_AI_RATIO=85
FACEBOOK_AGENT_REEL_RATIO=45
FACEBOOK_AGENT_VIDEO_DURATION=5
FACEBOOK_AGENT_JITTER_MINUTES=5
FACEBOOK_AGENT_HEALTH_CHECK=true
FACEBOOK_AGENT_RUN_ON_START=false
